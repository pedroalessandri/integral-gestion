{
  "name": "@gestion-publica/metrics-domain",
  "private": true,
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --no-splitting",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@gestion-publica/config-eslint": "workspace:*",
    "@gestion-publica/config-tsconfig": "workspace:*",
    "fast-check": "^3.23.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
