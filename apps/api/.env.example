# ─────────────────────────────────────────────────────────────
# apps/api — Environment variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://gp_user:gp_password@localhost:5432/gestion_publica?schema=public"

# Auth0
# Replace with your tenant values from the Auth0 dashboard.
# On startup the app logs a WARN if these are still placeholders.
AUTH0_ISSUER_BASE_URL="https://placeholder.auth0.com"
AUTH0_AUDIENCE="https://api.gestion-publica.placeholder"

# Bootstrapping
# Email of the first superadmin user. Used by CoreModule on first startup.
CORE_BOOTSTRAP_SUPERADMIN_EMAIL="admin@example.com"

# Rate limiting (optional — NestJS ThrottlerModule defaults apply if absent)
# THROTTLE_TTL_SECONDS=60
# THROTTLE_LIMIT=100

# Cron — Period auto-close (cron expression, default: hourly)
PERIOD_AUTO_CLOSE_CRON=0 * * * *

# AI Copilot (ADR-0005) — optional in dev, required in prod when AI is enabled
AI_DEFAULT_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...  (optional, for future OpenAI provider)
