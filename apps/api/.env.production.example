# ===== Database =====
DATABASE_URL=postgres://user:pass@host:port/db

# ===== Auth0 =====
AUTH0_ISSUER_BASE_URL=https://gestion-publica-dev.us.auth0.com
AUTH0_AUDIENCE=https://api.gestion-publica.ar

# ===== CORS =====
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ===== Bootstrap =====
CORE_BOOTSTRAP_SUPERADMIN_EMAIL=your-email@example.com

# ===== AI Copilot (ADR-0005) =====
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...  (optional, for future OpenAI provider)

# ===== Runtime =====
NODE_ENV=production
# PORT is set by Railway automatically
